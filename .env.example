# Copia este archivo a .env y completa los valores (no subas .env a GitHub).
# App: https://developers.mercadolibre.com/

ML_CLIENT_ID=tu_client_id
ML_CLIENT_SECRET=tu_client_secret
ML_REDIRECT_URI=https://andesautopartscl-sketch.github.io/WebAndesAutoParts/

# Solo la primera vez, tras autorizar la app (código de un solo uso):
# ML_AUTH_CODE=TG-xxxxxxxx

# Se rellenan automáticamente al ejecutar npm run sync-ml:
# ML_ACCESS_TOKEN=
# ML_REFRESH_TOKEN=
